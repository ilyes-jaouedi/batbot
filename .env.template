# Copy this file to .env and fill in your values
# cp .env.template .env

# ── Authentication (choose ONE option) ────────────────────────────────────────

# Option A — Vertex AI (recommended for GCP users)
# Run: gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Option B — Gemini API key (no GCP account needed)
# Get a key at: https://aistudio.google.com/app/apikey
# Comment out the Vertex AI lines above and set this instead:
# GOOGLE_API_KEY=

# ── Telegram Bot ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram user ID (get from @userinfobot)
ALLOWED_USER_ID=

# Password to unlock the bot at session start
BOT_PASSWORD=

# ── Email Integration (IMAP / SMTP) ───────────────────────────────────────────
EMAIL_ADDRESS=
EMAIL_PASSWORD=

# ── Academic APIs (optional) ──────────────────────────────────────────────────
# IEEE Xplore API key: https://developer.ieee.org
IEEE_API_KEY=

# IEEE full-text token (for subscription content)
IEEE_AUTH_TOKEN=
